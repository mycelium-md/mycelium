# Database — SQLite for local dev, set Postgres URL for production
DATABASE_URL="file:./mycelium.db"

# Claude API (required for task analysis and execution)
ANTHROPIC_API_KEY=""

# Search API (for agents with web_search capability — get key at tavily.com)
