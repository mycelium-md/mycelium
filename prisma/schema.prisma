// Mycelium Prisma Schema
// SQLite for local dev (DATABASE_URL="file:./mycelium.db")
// Postgres for production (DATABASE_URL="postgresql://...")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = env("DATABASE_PROVIDER")
  url      = env("DATABASE_URL")
}

model Agent {
  id           String           @id @default(uuid())
  name         String
  capabilities String           // JSON array stored as string (compat with SQLite + Postgres)
  createdAt    DateTime         @default(now())
  taskCount    Int              @default(0)
  coalitions   CoalitionAgent[]
}

model Task {
  id           String     @id @default(uuid())
  description  String
  requiredCaps String     // JSON array stored as string
  status       String     @default("PENDING")
  result       String?
  createdAt    DateTime   @default(now())
  completedAt  DateTime?
  coalition    Coalition?
}

model Coalition {
  id          String           @id @default(uuid())
  taskId      String           @unique
  status      String           @default("FORMING")
  createdAt   DateTime         @default(now())
  dissolvedAt DateTime?
  agents      CoalitionAgent[]
  task        Task             @relation(fields: [taskId], references: [id])
}

model CoalitionAgent {
  coalition   Coalition @relation(fields: [coalitionId], references: [id])
  coalitionId String
  agent       Agent     @relation(fields: [agentId], references: [id])
  agentId     String

  @@id([coalitionId, agentId])
}
